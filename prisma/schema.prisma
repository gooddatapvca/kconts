generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 프로그램 (관리툴에서 조회/요일 업데이트에 사용)
model Project {
  pj_seq         BigInt   @id
  pjname         String   @db.VarChar(300)
  project_status Int?
  ptype          String?  @db.Char(1)
  cat_id         String?  @db.Char(6)
  class_id       String?  @db.Char(5)
  client_idx     String?  @db.Char(1)
  pj_startdate   DateTime?
  pj_enddate     DateTime?
  service_day    Int[]
  service_day2   String?  @db.VarChar(10)
  moddate        DateTime?
  catd_id        String?  @db.Char(7)
  par_class_id   String?  @db.Char(5)
  crtime         String[]
  crtype         String?  @db.Char(1)
  tnms_pjname    String?  @db.VarChar(255)
  bodysizelimit  Int?
  cr_status      Int?

  @@map("project")
}

/// 방송국 리스트
model Pclass {
  class_id     String  @id @db.Char(5)
  class_name   String? @db.VarChar(100)
  par_class_id String? @db.Char(5)
  status       Int?

  @@map("pclass")
}

/// 다중 방송국 등록 (프로그램별 추가 방송사)
model GrpPclass {
  class_id     String  @db.Char(5)
  grp_class_id String? @db.VarChar(255)
  pj_seq       BigInt

  @@id([class_id, pj_seq])
  @@index([pj_seq], map: "idx_grp_pclass")
  @@map("grp_pclass")
}

/// 트위터 수동수집대상 (truncate -> insert)
model XxxPjlist1 {
  pj_seq BigInt @id

  @@map("xxx_pjlist1")
}

/// 토픽(출연자) — top_status: 1 사용, 0 미사용
model Topic {
  top_seq     Int      @id(map: "topic_pk") @default(autoincrement())
  top_name    String   @db.VarChar(100)
  par_top_seq Int
  pj_seq      Int
  moddate     DateTime @default(now()) @db.Timestamp(6)
  topic_type  String   @db.VarChar(10)
  person_seq  BigInt?
  top_status  Int?     @default(1) @db.SmallInt

  @@index([pj_seq], map: "idx_topic_pjseq")
  @@index([person_seq], map: "idx_topic_pseq")
  @@map("topic")
}

/// 토픽 타입 정의 — topic.topic_type 과 매칭
model Topictype {
  topic_type      String    @id @db.VarChar(10)
  topic_type_name String?   @db.VarChar(50)
  moddate         DateTime? @default(now()) @db.Timestamp(6)

  @@map("topictype")
}

/// 수집 문서 (필터링 대상) — conts_status: 0 삭제, 1 서비스, 3 자동삭제, 9 수집중
model RawContents {
  conts_seq    Int       @id @default(autoincrement())
  pj_seq       Int
  site_id      String?   @db.Char(8)
  title        String?   @db.VarChar(2000)
  body         String?
  writer       String?   @db.VarChar(200)
  wdate        DateTime? @db.Timestamp(6)
  cwdate       DateTime? @db.Timestamp(6)
  conts_status Int?      @default(1) @db.SmallInt
  rp_count     Int?      @default(0)
  origin       String?   @db.VarChar(100)
  v_count      Int?      @default(0)
  origin_link  String?   @db.VarChar(1000)
  week_cd      String?   @db.VarChar(10)

  @@index([pj_seq], map: "idx_raw_contents_pj_seq")
  @@map("raw_contents")
}

/// 수집 대상 사이트
model Site {
  site_id     String    @id @db.Char(8)
  chan_id     String    @db.Char(5)
  site_status Int?
  moddate     DateTime? @db.Timestamp(6)
  site_name   String?   @db.VarChar(100)
  gravity     Float?

  @@map("site")
}

/// 채널 (site.chan_id) — 필터링 화면에서 뉴스/VON/VD/SNS 구분에 사용
model Channel {
  chan_id     String    @id @db.Char(5)
  chan_name   String?   @db.VarChar(100)
  moddate     DateTime? @db.Timestamp(6)
  chan_status Int?

  @@map("channel")
}
